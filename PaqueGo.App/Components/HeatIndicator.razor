<MudPaper Class="@($"heat-indicator heat-{Level.ToString().ToLowerInvariant()}")" Elevation="0">
    <div class="heat-lights" aria-hidden="true">
        <span class="heat-light @(Level == HeatLevel.Cold ? "active" : string.Empty)"></span>
        <span class="heat-light @(Level == HeatLevel.Warm ? "active" : string.Empty)"></span>
        <span class="heat-light @(Level == HeatLevel.Hot ? "active" : string.Empty)"></span>
    </div>
    <div class="heat-copy">
        <MudText Typo="Typo.h6">@Title</MudText>
        <MudText Typo="Typo.body2">@Subtitle</MudText>
    </div>
</MudPaper>

@code {
    [Parameter]
    public HeatLevel Level { get; set; }

    [Parameter]
    public double? DistanceMeters { get; set; }

    private string Title => Level switch
    {
        HeatLevel.Hot => "Chaud",
        HeatLevel.Warm => "Tiède",
        HeatLevel.Cold => "Froid",
        _ => "Recherche"
    };

    private string Subtitle => Level switch
    {
        HeatLevel.Hot => "Chaud quand tu es à moins de 5 mètres.",
        HeatLevel.Warm => "Tiède quand tu es à moins de 10 mètres.",
        HeatLevel.Cold => "Froid quand tu es à plus de 10 mètres.",
        _ => "Bouge un peu pour réveiller la boussole."
    };
}