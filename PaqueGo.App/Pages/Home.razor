@page "/hunt"
@implements IDisposable
@inject EggHuntService HuntService
@inject NavigationManager Navigation

<PageTitle>Chasse aux trésors de Pâque</PageTitle>

<div class="hunt-screen hunt-play-screen heat-@HuntService.HeatLevel.ToString().ToLowerInvariant()">
	<div class="sky-layer">
		<span class="cloud cloud-one"></span>
		<span class="cloud cloud-two"></span>
		<span class="cloud cloud-three"></span>
		<span class="spark spark-one"></span>
		<span class="spark spark-two"></span>
		<span class="spark spark-three"></span>
	</div>

	<div class="decor-garden" aria-hidden="true">
		<span class="decor-egg egg-one"></span>
		<span class="decor-egg egg-two"></span>
		<span class="decor-egg egg-three"></span>
		<span class="decor-egg egg-four"></span>

		<div class="decor-bunny bunny-one">
			<span class="bunny-body"></span>
			<span class="bunny-head"></span>
			<span class="bunny-ear left"></span>
			<span class="bunny-ear right"></span>
			<span class="bunny-tail"></span>
		</div>

		<div class="decor-bunny bunny-two">
			<span class="bunny-body"></span>
			<span class="bunny-head"></span>
			<span class="bunny-ear left"></span>
			<span class="bunny-ear right"></span>
			<span class="bunny-tail"></span>
		</div>
	</div>

	@if (showTransition)
	{
		<div class="transition-overlay" aria-hidden="true">
			<div class="transition-card">
				<div class="transition-ribbon">La chasse commence</div>
				<h1>Chasse aux trésors de Pâque</h1>
				<p>Les oeufs scintillent, la boussole s'éveille et le jardin se transforme en terrain d'aventure.</p>
				<div class="transition-eggs">
					<span class="transition-egg egg-one"></span>
					<span class="transition-egg egg-two"></span>
					<span class="transition-egg egg-three"></span>
				</div>
			</div>
		</div>
	}

	<section class="play-stage">
		<section class="play-layout">
			<MudPaper Class="game-card compass-card immersive-compass-card mud-shell-card" Elevation="0">
				<div class="hunt-panel-copy">
					<h1>La boussole te guide vers le trésor</h1>
					@if (!string.IsNullOrWhiteSpace(runtimeMessage))
					{
						<MudAlert Severity="Severity.Error"
								  Variant="Variant.Filled"
								  Dense="true"
								  Class="upload-message mud-message is-error">
							@runtimeMessage
						</MudAlert>
					}

					@if (HuntService.ActiveTarget is not null)
					{
						<div class="active-target-label">
							<MudText Typo="Typo.overline" Class="section-label mud-overline">Point actuel</MudText>
							<MudText Typo="Typo.h5">@HuntService.ActiveTarget.Name</MudText>
						</div>
					}
				</div>

			<CompassDisplay RelativeBearingDegrees="@HuntService.RelativeBearingDegrees"
							DistanceMeters="@HuntService.DistanceToTargetMeters"
							HeatLevel="@HuntService.HeatLevel"
							IsLive="@HuntService.Snapshot.IsHeadingAvailable"
							TargetName="@HuntService.ActiveTarget?.Name" />

				<div class="distance-panel">
					<MudText Typo="Typo.overline" Class="section-label mud-overline">Distance à parcourir</MudText>
					<MudText Typo="Typo.h4" Class="distance-value">@DistanceLabel</MudText>
				</div>

			<HeatIndicator Level="@HuntService.HeatLevel" DistanceMeters="@HuntService.DistanceToTargetMeters" />

				@if (!string.IsNullOrWhiteSpace(HuntService.ActiveTarget?.Hint))
				{
					<MudChip T="string" Class="hint-bubble hint-pill" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info">
						Indice : @HuntService.ActiveTarget.Hint
					</MudChip>
				}

				<div class="compass-footer-actions">
					<MudButton Variant="Variant.Filled"
							   Color="Color.Success"
							   StartIcon="@Icons.Material.Filled.CheckCircle"
							   OnClick="@MarkCurrentTargetFoundAsync"
							   Disabled="@(HuntService.ActiveTarget is null)"
							   Class="success-button compass-primary-action">
						Oeuf trouvé !
					</MudButton>
				</div>

				@if (HuntService.IsCompleted)
				{
					<MudAlert Severity="Severity.Success"
							  Variant="Variant.Filled"
							  Dense="true"
							  Class="celebration-box">
						<MudText Typo="Typo.h6">Bravo, tous les oeufs sont trouvés !</MudText>
						<MudText Typo="Typo.body2">Le lapin de Pâque saute de joie.</MudText>
					</MudAlert>
				}
			</MudPaper>
	</section>
	</section>

	@if (HuntService.IsCompleted)
	{
		<div class="confetti-rain" aria-hidden="true">
			<span></span>
			<span></span>
			<span></span>
			<span></span>
			<span></span>
			<span></span>
		</div>
	}
</div>

@code {
	private readonly PeriodicTimer _refreshTimer = new(TimeSpan.FromSeconds(1));
	private readonly CancellationTokenSource _refreshCts = new();
	private bool showTransition = true;
	private string? runtimeMessage;

	protected override async Task OnInitializedAsync()
	{
		HuntService.StateChanged += HandleStateChanged;
		try
		{
			await HuntService.InitializeAsync();

			if (!HuntService.HasTargets)
			{
				Navigation.NavigateTo(string.Empty, replace: true);
				return;
			}

			_ = PollAsync(_refreshCts.Token);
		}
		catch (Exception exception)
		{
			runtimeMessage = $"L'application n'a pas pu démarrer correctement : {exception.Message}";
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || !HuntService.HasTargets)
		{
			return;
		}

		await HuntService.ResumeSensorsAsync();
		await HuntService.TryEnterFullscreenAsync();
		await Task.Delay(2200);
		showTransition = false;
		await InvokeAsync(StateHasChanged);
	}

	private string DistanceLabel => HuntMath.ToFriendlyDistance(HuntService.DistanceToTargetMeters);

	private async Task PollAsync(CancellationToken cancellationToken)
	{
		try
		{
			while (await _refreshTimer.WaitForNextTickAsync(cancellationToken))
			{
				await HuntService.RefreshAsync();
			}
		}
		catch (OperationCanceledException)
		{
		}
		catch (ObjectDisposedException)
		{
		}
		catch (Exception exception)
		{
			runtimeMessage = $"Le rafraîchissement automatique a été interrompu : {exception.Message}";
			await InvokeAsync(StateHasChanged);
		}
	}

	private void HandleStateChanged()
	{
		_ = InvokeAsync(StateHasChanged);
	}

	private async Task MarkCurrentTargetFoundAsync()
	{
		await HuntService.MarkCurrentTargetFoundAsync();
	}

	public void Dispose()
	{
		HuntService.StateChanged -= HandleStateChanged;
		_refreshCts.Cancel();
		_refreshTimer.Dispose();
		_refreshCts.Dispose();
	}
}
