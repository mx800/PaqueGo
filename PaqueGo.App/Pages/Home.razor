@page "/hunt"
@implements IDisposable
@inject EggHuntService HuntService
@inject NavigationManager Navigation

<PageTitle>Chasse aux trésors de Pâque</PageTitle>

<div class="hunt-screen hunt-play-screen heat-@HuntService.HeatLevel.ToString().ToLowerInvariant()">
	<AnimatedEasterScene SceneClass="scene-hunt" />

	@if (showTransition)
	{
		<div class="transition-overlay" aria-hidden="true">
			<div class="transition-card">
				<div class="transition-ribbon">La chasse commence</div>
				<h1>Chasse aux trésors de Pâque</h1>
				<p>Les oeufs scintillent, la boussole s'éveille et le jardin se transforme en terrain d'aventure.</p>
				<div class="transition-eggs">
					<span class="transition-egg egg-one"></span>
					<span class="transition-egg egg-two"></span>
					<span class="transition-egg egg-three"></span>
				</div>
			</div>
		</div>
	}

	@if (showEggFoundSequence)
	{
		<div class="found-overlay"
			 role="button"
			 tabindex="0"
			 aria-label="Passer au prochain oeuf"
			 @onclick="CompleteEggFoundSequenceAsync"
			 @onkeydown="HandleFoundOverlayKeyDown">
			<div class="found-overlay-shell">
				<div class="found-burst" aria-hidden="true">
					<span class="found-ray ray-one"></span>
					<span class="found-ray ray-two"></span>
					<span class="found-ray ray-three"></span>
					<span class="found-ray ray-four"></span>
					<span class="found-ray ray-five"></span>
					<span class="found-ray ray-six"></span>
					<span class="found-spark spark-one"></span>
					<span class="found-spark spark-two"></span>
					<span class="found-spark spark-three"></span>
					<span class="found-spark spark-four"></span>
					<span class="found-spark spark-five"></span>
					<span class="found-spark spark-six"></span>
					<div class="found-core-glow"></div>
					<div class="found-egg-mark"></div>
				</div>

				<div class="found-overlay-card">
					<div class="found-overlay-ribbon">@foundSequenceRibbon</div>
					<h2>@foundSequenceTitle</h2>
					@if (!string.IsNullOrWhiteSpace(foundSequenceEggName))
					{
						<p class="found-overlay-name">@foundSequenceEggName</p>
					}
					<p>@foundSequenceMessage</p>
					<p class="found-overlay-hint">Touchez l'ecran pour continuer</p>
				</div>
			</div>
		</div>
	}

	<section class="play-stage">
		<section class="play-layout">
			<MudPaper Class="game-card compass-card immersive-compass-card mud-shell-card" Elevation="0">
				<div class="hunt-panel-copy">
					<h1>La boussole te guide vers le trésor</h1>
					@if (!string.IsNullOrWhiteSpace(runtimeMessage))
					{
						<MudAlert Severity="Severity.Error"
								  Variant="Variant.Filled"
								  Dense="true"
								  Class="upload-message mud-message is-error">
							@runtimeMessage
						</MudAlert>
					}

					@if (HuntService.ActiveTarget is not null)
					{
						<div class="active-target-label">
							<MudText Typo="Typo.overline" Class="section-label mud-overline">Point actuel</MudText>
							<MudText Typo="Typo.h5">@HuntService.ActiveTarget.Name</MudText>
						</div>
					}
				</div>

			<CompassDisplay RelativeBearingDegrees="@HuntService.RelativeBearingDegrees"
							DistanceMeters="@HuntService.DistanceToTargetMeters"
							HeatLevel="@HuntService.HeatLevel"
							IsLive="@HuntService.Snapshot.IsHeadingAvailable"
							TargetName="@HuntService.ActiveTarget?.Name" />

				<div class="distance-panel">
					<MudText Typo="Typo.overline" Class="section-label mud-overline">Distance à parcourir</MudText>
					<MudText Typo="Typo.h4" Class="distance-value">@DistanceLabel</MudText>
				</div>

			<HeatIndicator Level="@HuntService.HeatLevel" DistanceMeters="@HuntService.DistanceToTargetMeters" />

				@if (!string.IsNullOrWhiteSpace(HuntService.ActiveTarget?.Hint))
				{
					<MudChip T="string" Class="hint-bubble hint-pill" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info">
						Indice : @HuntService.ActiveTarget.Hint
					</MudChip>
				}

				<div class="compass-footer-actions">
					<MudButton Variant="Variant.Filled"
							   Color="Color.Success"
							   StartIcon="@Icons.Material.Filled.CheckCircle"
							   OnClick="@MarkCurrentTargetFoundAsync"
							   Disabled="@(HuntService.ActiveTarget is null || isFindingEgg)"
							   Class="success-button compass-primary-action">
						Oeuf trouvé !
					</MudButton>
				</div>

				@if (HuntService.IsCompleted)
				{
					<MudAlert Severity="Severity.Success"
							  Variant="Variant.Filled"
							  Dense="true"
							  Class="celebration-box">
						<MudText Typo="Typo.h6">Bravo, tous les oeufs sont trouvés !</MudText>
						<MudText Typo="Typo.body2">Le lapin de Pâque saute de joie.</MudText>
					</MudAlert>
				}
			</MudPaper>
	</section>
	</section>

	@if (HuntService.IsCompleted)
	{
		<VictoryCelebration />
		<div class="confetti-rain" aria-hidden="true">
			<span></span>
			<span></span>
			<span></span>
			<span></span>
			<span></span>
			<span></span>
		</div>
	}
</div>

@code {
	private readonly PeriodicTimer _refreshTimer = new(TimeSpan.FromSeconds(1));
	private readonly CancellationTokenSource _refreshCts = new();
	private bool showTransition = true;
	private bool showEggFoundSequence;
	private bool isFindingEgg;
	private bool isCompletingEggFoundSequence;
	private string foundSequenceRibbon = "Oeuf trouve";
	private string foundSequenceTitle = string.Empty;
	private string foundSequenceMessage = string.Empty;
	private string? foundSequenceEggName;
	private string? pendingFoundTargetId;
	private string? runtimeMessage;

	protected override async Task OnInitializedAsync()
	{
		HuntService.StateChanged += HandleStateChanged;
		try
		{
			await HuntService.InitializeAsync();

			if (!HuntService.HasTargets)
			{
				Navigation.NavigateTo(string.Empty, replace: true);
				return;
			}

			_ = PollAsync(_refreshCts.Token);
		}
		catch (Exception exception)
		{
			runtimeMessage = $"L'application n'a pas pu démarrer correctement : {exception.Message}";
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || !HuntService.HasTargets)
		{
			return;
		}

		await HuntService.ResumeSensorsAsync();
		await HuntService.TryEnterFullscreenAsync();
		await Task.Delay(1350);
		showTransition = false;
		await InvokeAsync(StateHasChanged);
	}

	private string DistanceLabel => HuntMath.ToFriendlyDistance(HuntService.DistanceToTargetMeters);

	private async Task PollAsync(CancellationToken cancellationToken)
	{
		try
		{
			while (await _refreshTimer.WaitForNextTickAsync(cancellationToken))
			{
				await HuntService.RefreshAsync();
			}
		}
		catch (OperationCanceledException)
		{
		}
		catch (ObjectDisposedException)
		{
		}
		catch (Exception exception)
		{
			runtimeMessage = $"Le rafraîchissement automatique a été interrompu : {exception.Message}";
			await InvokeAsync(StateHasChanged);
		}
	}

	private void HandleStateChanged()
	{
		_ = InvokeAsync(StateHasChanged);
	}

	private async Task MarkCurrentTargetFoundAsync()
	{
		if (isFindingEgg || HuntService.ActiveTarget is null)
		{
			return;
		}

		var currentTargetName = string.IsNullOrWhiteSpace(HuntService.ActiveTarget.Name)
			? "Un oeuf mystere"
			: HuntService.ActiveTarget.Name;
		pendingFoundTargetId = HuntService.ActiveTarget.Id;
		var isFinalEgg = HuntService.FoundCount + 1 >= HuntService.TotalCount;

		foundSequenceRibbon = isFinalEgg ? "Dernier oeuf" : "Oeuf trouve";
		foundSequenceTitle = isFinalEgg ? "Le panier s'illumine" : "Une etincelle traverse le jardin";
		foundSequenceEggName = currentTargetName;
		foundSequenceMessage = isFinalEgg
			? "Une pluie doree attend ton signal pour lancer le final."
			: "Le sentier magique se revele. Appuie pour faire apparaitre la prochaine piste.";

		showEggFoundSequence = true;
		isFindingEgg = true;
		await InvokeAsync(StateHasChanged);
	}

	private async Task CompleteEggFoundSequenceAsync()
	{
		if (!showEggFoundSequence || !isFindingEgg || isCompletingEggFoundSequence || string.IsNullOrWhiteSpace(pendingFoundTargetId))
		{
			return;
		}

		isCompletingEggFoundSequence = true;

		try
		{
			await HuntService.MarkTargetFoundAsync(pendingFoundTargetId);
		}
		catch (Exception exception)
		{
			runtimeMessage = $"Impossible de valider cet oeuf : {exception.Message}";
		}
		finally
		{
			showEggFoundSequence = false;
			isFindingEgg = false;
			isCompletingEggFoundSequence = false;
			foundSequenceEggName = null;
			pendingFoundTargetId = null;
			await InvokeAsync(StateHasChanged);
		}
	}

	private Task HandleFoundOverlayKeyDown(KeyboardEventArgs eventArgs)
	{
		if (eventArgs.Key is "Enter" or " ")
		{
			return CompleteEggFoundSequenceAsync();
		}

		return Task.CompletedTask;
	}

	public void Dispose()
	{
		HuntService.StateChanged -= HandleStateChanged;
		_refreshCts.Cancel();
		_refreshTimer.Dispose();
		_refreshCts.Dispose();
	}
}
