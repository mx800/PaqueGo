@page "/hunt"
@implements IAsyncDisposable
@inject EggHuntService HuntService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Chasse aux trésors de Pâque</PageTitle>

<div class="hunt-screen hunt-play-screen heat-@HuntService.HeatLevel.ToString().ToLowerInvariant()">
	<AnimatedEasterScene SceneClass="scene-hunt" />

	@if (showTransition)
	{
		<div class="transition-overlay" aria-hidden="true">
			<div class="transition-card">
				<div class="transition-ribbon">La chasse commence</div>
				<h1>Chasse aux trésors de Pâque</h1>
				<p>Les oeufs scintillent, la boussole s'éveille et le jardin se transforme en terrain d'aventure.</p>
				<div class="transition-eggs">
					<span class="transition-egg egg-one"></span>
					<span class="transition-egg egg-two"></span>
					<span class="transition-egg egg-three"></span>
				</div>
			</div>
		</div>
	}

	@if (showEggFoundSequence)
	{
		<div class="found-overlay"
			 role="button"
			 tabindex="0"
			 aria-label="Passer au prochain oeuf"
			 @onclick="CompleteEggFoundSequenceAsync"
			 @onkeydown="HandleFoundOverlayKeyDown">
			<div class="found-overlay-shell">
				<div class="found-burst" aria-hidden="true">
					<span class="found-ray ray-one"></span>
					<span class="found-ray ray-two"></span>
					<span class="found-ray ray-three"></span>
					<span class="found-ray ray-four"></span>
					<span class="found-ray ray-five"></span>
					<span class="found-ray ray-six"></span>
					<span class="found-spark spark-one"></span>
					<span class="found-spark spark-two"></span>
					<span class="found-spark spark-three"></span>
					<span class="found-spark spark-four"></span>
					<span class="found-spark spark-five"></span>
					<span class="found-spark spark-six"></span>
					<div class="found-core-glow"></div>
					<div class="found-egg-mark"></div>
				</div>

				<div class="found-overlay-card">
					<div class="found-overlay-ribbon">@foundSequenceRibbon</div>
					<h2>@foundSequenceTitle</h2>
					@if (!string.IsNullOrWhiteSpace(foundSequenceEggName))
					{
						<p class="found-overlay-name">@foundSequenceEggName</p>
					}
					<p>@foundSequenceMessage</p>
					<p class="found-overlay-hint">Touchez l'ecran pour continuer</p>
				</div>
			</div>
		</div>
	}

	@if (showFinalVictorySequence)
	{
		<div class="final-overlay" aria-label="Celebration finale du tresor">
			<div class="final-victory-parade">
				<VictoryCelebration />
			</div>
			<div class="final-overlay-shell">
				<div class="final-overlay-stage" aria-hidden="true">
					<span class="final-beam beam-one"></span>
					<span class="final-beam beam-two"></span>
					<span class="final-beam beam-three"></span>
					<span class="final-beam beam-four"></span>
					<span class="final-beam beam-five"></span>
					<span class="final-beam beam-six"></span>
					<span class="final-glitter glitter-one"></span>
					<span class="final-glitter glitter-two"></span>
					<span class="final-glitter glitter-three"></span>
					<span class="final-glitter glitter-four"></span>
					<span class="final-glitter glitter-five"></span>
					<span class="final-glitter glitter-six"></span>
					<div class="final-core-glow"></div>
					<svg class="final-treasure-svg" viewBox="0 0 320 280" role="presentation">
						<defs>
							<linearGradient id="treasureLidGradient" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="#7a4619" />
								<stop offset="100%" stop-color="#4d2708" />
							</linearGradient>
							<linearGradient id="treasureWoodGradient" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0%" stop-color="#a96324" />
								<stop offset="100%" stop-color="#71370f" />
							</linearGradient>
							<linearGradient id="treasureGoldGradient" x1="0" y1="0" x2="1" y2="1">
								<stop offset="0%" stop-color="#fff3ae" />
								<stop offset="55%" stop-color="#ffd24f" />
								<stop offset="100%" stop-color="#ffb326" />
							</linearGradient>
							<radialGradient id="treasureGlowGradient" cx="50%" cy="40%" r="65%">
								<stop offset="0%" stop-color="rgba(255,250,214,0.98)" />
								<stop offset="65%" stop-color="rgba(255,216,107,0.55)" />
								<stop offset="100%" stop-color="rgba(255,216,107,0)" />
							</radialGradient>
						</defs>

						<ellipse class="treasure-floor-shadow" cx="160" cy="244" rx="106" ry="24" />
						<ellipse class="treasure-inner-glow" cx="160" cy="120" rx="110" ry="84" fill="url(#treasureGlowGradient)" />

						<g class="treasure-coins-back">
							<circle class="treasure-coin coin-a" cx="110" cy="134" r="18" />
							<circle class="treasure-coin coin-b" cx="138" cy="120" r="20" />
							<circle class="treasure-coin coin-c" cx="182" cy="118" r="19" />
							<circle class="treasure-coin coin-d" cx="212" cy="134" r="17" />
						</g>

						<g class="treasure-lid">
							<path d="M82 72C82 50 99 34 122 34H198C221 34 238 50 238 72V92H82V72Z" fill="url(#treasureLidGradient)" />
							<path d="M72 92C72 66 92 48 118 48H202C228 48 248 66 248 92V112H72V92Z" fill="url(#treasureWoodGradient)" />
							<path d="M88 92C88 71 104 58 124 58H196C216 58 232 71 232 92V102H88V92Z" fill="#ffdf6f" opacity="0.72" />
							<rect x="72" y="94" width="176" height="16" rx="8" fill="url(#treasureGoldGradient)" />
							<rect x="150" y="74" width="20" height="38" rx="10" fill="url(#treasureGoldGradient)" />
						</g>

						<g class="treasure-box">
							<rect x="74" y="112" width="172" height="112" rx="24" fill="url(#treasureWoodGradient)" />
							<rect x="86" y="126" width="148" height="84" rx="18" fill="#8f4f1b" opacity="0.82" />
							<rect x="74" y="130" width="172" height="18" rx="9" fill="url(#treasureGoldGradient)" />
							<rect x="74" y="170" width="172" height="18" rx="9" fill="url(#treasureGoldGradient)" />
							<rect x="108" y="112" width="18" height="112" rx="9" fill="url(#treasureGoldGradient)" />
							<rect x="194" y="112" width="18" height="112" rx="9" fill="url(#treasureGoldGradient)" />
							<rect x="144" y="144" width="32" height="46" rx="14" fill="url(#treasureGoldGradient)" />
							<circle cx="160" cy="164" r="7" fill="#8a5310" />
						</g>

						<g class="treasure-coins-front">
							<circle class="treasure-coin coin-e" cx="116" cy="164" r="18" />
							<circle class="treasure-coin coin-f" cx="144" cy="150" r="18" />
							<circle class="treasure-coin coin-g" cx="174" cy="150" r="18" />
							<circle class="treasure-coin coin-h" cx="202" cy="164" r="17" />
							<path class="treasure-gem gem-a" d="M114 196l14-20 14 20-14 18-14-18Z" />
							<path class="treasure-gem gem-b" d="M186 192l12-16 12 16-12 18-12-18Z" />
							<path class="treasure-gem gem-c" d="M154 202l10-14 10 14-10 16-10-16Z" />
						</g>
					</svg>
					<div class="final-overlay-eggs">
						<span class="final-egg final-egg-one"></span>
						<span class="final-egg final-egg-two"></span>
						<span class="final-egg final-egg-three"></span>
					</div>
				</div>

				<div class="final-overlay-card">
					<div class="final-overlay-ribbon">Victoire de Paque</div>
					<h2>Le coffre au tresor est ouvert</h2>
					<p class="final-overlay-name">Tous les oeufs sont trouves</p>
					<p>Le butin dore scintille au milieu du jardin. Une pluie d'oeufs colores et des pierres precieuses celebrent la fin de la chasse.</p>
					<div class="final-overlay-actions">
						<MudButton Variant="Variant.Outlined"
								   Color="Color.Warning"
								   StartIcon="@Icons.Material.Filled.RestartAlt"
								   OnClick="@RestartAdventureAsync">
							Recommencer
						</MudButton>
					</div>
					<p class="final-overlay-hint">Choisis la suite depuis cette carte</p>
				</div>
			</div>
		</div>
	}

	<section class="play-stage">
		<section class="play-layout">
			<MudPaper Class="game-card compass-card immersive-compass-card mud-shell-card" Elevation="0">
				<div class="hunt-panel-copy">
					<h1>La boussole te guide vers le trésor</h1>
					@if (!string.IsNullOrWhiteSpace(runtimeMessage))
					{
						<MudAlert Severity="Severity.Error"
								  Variant="Variant.Filled"
								  Dense="true"
								  Class="upload-message mud-message is-error">
							@runtimeMessage
						</MudAlert>
					}

					@if (HuntService.ActiveTarget is not null)
					{
						<div class="active-target-label">
							<MudText Typo="Typo.overline" Class="section-label mud-overline">Point actuel</MudText>
							<MudText Typo="Typo.h5">@HuntService.ActiveTarget.Name</MudText>
						</div>
					}
				</div>

			<CompassDisplay RelativeBearingDegrees="@HuntService.RelativeBearingDegrees"
							DistanceMeters="@HuntService.DistanceToTargetMeters"
							HeatLevel="@HuntService.HeatLevel"
							IsLive="@(HuntService.Snapshot.IsHeadingAvailable || HuntService.Snapshot.IsLocationAvailable)"
							TargetName="@HuntService.ActiveTarget?.Name" />

				<div class="distance-panel">
					<MudText Typo="Typo.overline" Class="section-label mud-overline">Distance à parcourir</MudText>
					<MudText Typo="Typo.h4" Class="distance-value">@DistanceLabel</MudText>
				</div>

			<HeatIndicator Level="@HuntService.HeatLevel" DistanceMeters="@HuntService.DistanceToTargetMeters" />

				@if (!string.IsNullOrWhiteSpace(HuntService.ActiveTarget?.Hint))
				{
					<MudChip T="string" Class="hint-bubble hint-pill" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info">
						Indice : @HuntService.ActiveTarget.Hint
					</MudChip>
				}

				<div class="compass-footer-actions">
					<MudButton Variant="Variant.Filled"
							   Color="Color.Success"
							   StartIcon="@Icons.Material.Filled.CheckCircle"
							   OnClick="@MarkCurrentTargetFoundAsync"
							   Disabled="@(HuntService.ActiveTarget is null || isFindingEgg)"
							   Class="success-button compass-primary-action">
						Oeuf trouvé !
					</MudButton>
				</div>

				@if (HuntService.IsCompleted)
				{
					<div class="celebration-actions">
						<MudButton Variant="Variant.Outlined"
								   Color="Color.Warning"
								   StartIcon="@Icons.Material.Filled.RestartAlt"
								   OnClick="@RestartAdventureAsync">
							Recommencer depuis l'accueil
						</MudButton>
					</div>
				}
			</MudPaper>
	</section>
	</section>
</div>

@code {
	private readonly PeriodicTimer _refreshTimer = new(TimeSpan.FromSeconds(1));
	private readonly CancellationTokenSource _refreshCts = new();
	private bool showTransition = true;
	private bool showEggFoundSequence;
	private bool showFinalVictorySequence;
	private bool isFindingEgg;
	private bool isCompletingEggFoundSequence;
	private bool isPendingFinalEgg;
	private string foundSequenceRibbon = "Oeuf trouve";
	private string foundSequenceTitle = string.Empty;
	private string foundSequenceMessage = string.Empty;
	private string? foundSequenceEggName;
	private string? pendingFoundTargetId;
	private string? runtimeMessage;
	private bool audioStateDirty = true;
	private bool disposed;
	private int eggFoundSoundSequence;
	private int lastPlayedEggFoundSoundSequence;
	private HeatLevel? lastSyncedHeatLevel;
	private bool? lastSearchAmbienceState;
	private bool? lastFinalAmbienceState;

	protected override async Task OnInitializedAsync()
	{
		HuntService.StateChanged += HandleStateChanged;
		try
		{
			await HuntService.InitializeAsync();

			if (!HuntService.HasTargets)
			{
				Navigation.NavigateTo(string.Empty, replace: true);
				return;
			}

			_ = PollAsync(_refreshCts.Token);
		}
		catch (Exception exception)
		{
			runtimeMessage = $"L'application n'a pas pu démarrer correctement : {exception.Message}";
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender && HuntService.HasTargets)
		{
			await HuntService.ResumeSensorsAsync();
			await HuntService.TryEnterFullscreenAsync();
			await Task.Delay(1350);
			showTransition = false;
			audioStateDirty = true;
			await InvokeAsync(StateHasChanged);
		}

		if (!HuntService.HasTargets)
		{
			return;
		}

		await SyncAudioStateAsync(firstRender);
	}

	private string DistanceLabel => HuntMath.ToFriendlyDistance(HuntService.DistanceToTargetMeters);

	private bool IsSearchAmbienceActive =>
		HuntService.AdventureStarted &&
		HuntService.HasTargets &&
		!showEggFoundSequence &&
		!showFinalVictorySequence &&
		!HuntService.IsCompleted;

	private async Task PollAsync(CancellationToken cancellationToken)
	{
		try
		{
			while (await _refreshTimer.WaitForNextTickAsync(cancellationToken))
			{
				await HuntService.RefreshAsync();
			}
		}
		catch (OperationCanceledException)
		{
		}
		catch (ObjectDisposedException)
		{
		}
		catch (Exception exception)
		{
			runtimeMessage = $"Le rafraîchissement automatique a été interrompu : {exception.Message}";
			await InvokeAsync(StateHasChanged);
		}
	}

	private void HandleStateChanged()
	{
		audioStateDirty = true;
		_ = InvokeAsync(StateHasChanged);
	}

	private async Task SyncAudioStateAsync(bool force = false)
	{
		if (disposed || !HuntService.HasTargets)
		{
			return;
		}

		var isSearchActive = IsSearchAmbienceActive;
		var nextHeatLevel = isSearchActive ? HuntService.HeatLevel : HeatLevel.Unknown;
		var isFinalActive = showFinalVictorySequence;
		var shouldPlayEggFoundSound = showEggFoundSequence && lastPlayedEggFoundSoundSequence != eggFoundSoundSequence;

		if (!force &&
			!audioStateDirty &&
			lastSearchAmbienceState == isSearchActive &&
			lastSyncedHeatLevel == nextHeatLevel &&
			lastFinalAmbienceState == isFinalActive &&
			!shouldPlayEggFoundSound)
		{
			return;
		}

		try
		{
			await JS.InvokeVoidAsync("paqueGo.updateAudioState", new
			{
				isSearchActive,
				heatLevel = nextHeatLevel.ToString(),
				isFinalActive
			});

			if (shouldPlayEggFoundSound)
			{
				await JS.InvokeVoidAsync("paqueGo.playEggFound");
				lastPlayedEggFoundSoundSequence = eggFoundSoundSequence;
			}

			lastSearchAmbienceState = isSearchActive;
			lastSyncedHeatLevel = nextHeatLevel;
			lastFinalAmbienceState = isFinalActive;
			audioStateDirty = false;
		}
		catch (JSException)
		{
		}
		catch (TaskCanceledException)
		{
		}
		catch (ObjectDisposedException)
		{
		}
	}

	private async Task SafeStopAudioAsync()
	{
		try
		{
			await JS.InvokeVoidAsync("paqueGo.stopAllAudio");
		}
		catch (JSException)
		{
		}
		catch (TaskCanceledException)
		{
		}
		catch (ObjectDisposedException)
		{
		}
	}

	private async Task MarkCurrentTargetFoundAsync()
	{
		if (isFindingEgg || HuntService.ActiveTarget is null)
		{
			return;
		}

		var currentTargetName = string.IsNullOrWhiteSpace(HuntService.ActiveTarget.Name)
			? "Un oeuf mystere"
			: HuntService.ActiveTarget.Name;
		pendingFoundTargetId = HuntService.ActiveTarget.Id;
		var isFinalEgg = HuntService.FoundCount + 1 >= HuntService.TotalCount;
		isPendingFinalEgg = isFinalEgg;

		foundSequenceRibbon = isFinalEgg ? "Dernier oeuf" : "Oeuf trouve";
		foundSequenceTitle = isFinalEgg ? "Le panier s'illumine" : "Une etincelle traverse le jardin";
		foundSequenceEggName = currentTargetName;
		foundSequenceMessage = isFinalEgg
			? "Une pluie doree attend ton signal pour lancer le final."
			: "Le sentier magique se revele. Appuie pour faire apparaitre la prochaine piste.";

		eggFoundSoundSequence++;
		showEggFoundSequence = true;
		isFindingEgg = true;
		audioStateDirty = true;
		await InvokeAsync(StateHasChanged);
	}

	private async Task CompleteEggFoundSequenceAsync()
	{
		if (!showEggFoundSequence || !isFindingEgg || isCompletingEggFoundSequence || string.IsNullOrWhiteSpace(pendingFoundTargetId))
		{
			return;
		}

		isCompletingEggFoundSequence = true;
		var shouldShowFinalVictory = false;

		try
		{
			await HuntService.MarkTargetFoundAsync(pendingFoundTargetId);
			shouldShowFinalVictory = isPendingFinalEgg && HuntService.IsCompleted;
		}
		catch (Exception exception)
		{
			runtimeMessage = $"Impossible de valider cet oeuf : {exception.Message}";
		}
		finally
		{
			showEggFoundSequence = false;
			isCompletingEggFoundSequence = false;
			showFinalVictorySequence = shouldShowFinalVictory;
			isFindingEgg = shouldShowFinalVictory;
			foundSequenceEggName = null;
			pendingFoundTargetId = null;
			isPendingFinalEgg = false;
			audioStateDirty = true;
			await InvokeAsync(StateHasChanged);
		}
	}

	private Task HandleFoundOverlayKeyDown(KeyboardEventArgs eventArgs)
	{
		if (eventArgs.Key is "Enter" or " ")
		{
			return CompleteEggFoundSequenceAsync();
		}

		return Task.CompletedTask;
	}

	private async Task CloseFinalVictorySequenceAsync()
	{
		if (!showFinalVictorySequence)
		{
			return;
		}

		showFinalVictorySequence = false;
		isFindingEgg = false;
		audioStateDirty = true;
		await InvokeAsync(StateHasChanged);
	}

	private async Task RestartAdventureAsync()
	{
		try
		{
			await SafeStopAudioAsync();

			showEggFoundSequence = false;
			showFinalVictorySequence = false;
			isFindingEgg = false;
			isCompletingEggFoundSequence = false;
			isPendingFinalEgg = false;
			foundSequenceEggName = null;
			pendingFoundTargetId = null;
			runtimeMessage = null;
			lastPlayedEggFoundSoundSequence = 0;
			eggFoundSoundSequence = 0;
			audioStateDirty = true;

			await HuntService.ResetProgressAsync();
			Navigation.NavigateTo(string.Empty, replace: true);
		}
		catch (Exception exception)
		{
			runtimeMessage = $"Impossible de recommencer la chasse : {exception.Message}";
			await InvokeAsync(StateHasChanged);
		}
	}

	public async ValueTask DisposeAsync()
	{
		if (disposed)
		{
			return;
		}

		disposed = true;
		HuntService.StateChanged -= HandleStateChanged;
		_refreshCts.Cancel();
		_refreshTimer.Dispose();
		_refreshCts.Dispose();
		await SafeStopAudioAsync();
	}
}
