@page "/hunt"
@implements IDisposable
@inject EggHuntService HuntService
@inject NavigationManager Navigation

<PageTitle>Chasse aux trésors de Pâque</PageTitle>

<div class="hunt-screen hunt-play-screen heat-@HuntService.HeatLevel.ToString().ToLowerInvariant()">
	<div class="sky-layer">
		<span class="cloud cloud-one"></span>
		<span class="cloud cloud-two"></span>
		<span class="cloud cloud-three"></span>
		<span class="spark spark-one"></span>
		<span class="spark spark-two"></span>
		<span class="spark spark-three"></span>
	</div>

	@if (showTransition)
	{
		<div class="transition-overlay" aria-hidden="true">
			<div class="transition-card">
				<div class="transition-ribbon">La chasse commence</div>
				<h1>Chasse aux trésors de Pâque</h1>
				<p>Les oeufs scintillent, la boussole s'eveille et le jardin se transforme en terrain d'aventure.</p>
				<div class="transition-eggs">
					<span class="transition-egg egg-one"></span>
					<span class="transition-egg egg-two"></span>
					<span class="transition-egg egg-three"></span>
				</div>
			</div>
		</div>
	}

	<section class="play-stage">
		<div class="play-header hero-card">
			<div class="hero-copy">
				<h1>@HeroTitle</h1>
				@if (!string.IsNullOrWhiteSpace(runtimeMessage))
				{
					<div class="upload-message is-error">@runtimeMessage</div>
				}
			</div>
		</div>

		<section class="play-layout">
			<RadzenCard class="game-card compass-card immersive-compass-card">
				<div class="card-head compact">
					<div>
						<div class="section-label">Direction</div>
						<h2>@CompassTitle</h2>
					</div>
				</div>

			<CompassDisplay RelativeBearingDegrees="@HuntService.RelativeBearingDegrees"
							DistanceMeters="@HuntService.DistanceToTargetMeters"
							HeatLevel="@HuntService.HeatLevel"
							IsLive="@HuntService.Snapshot.IsHeadingAvailable"
							TargetName="@HuntService.ActiveTarget?.Name" />

			<HeatIndicator Level="@HuntService.HeatLevel" DistanceMeters="@HuntService.DistanceToTargetMeters" />

				@if (!string.IsNullOrWhiteSpace(HuntService.ActiveTarget?.Hint))
				{
					<div class="hint-bubble">Indice : @HuntService.ActiveTarget.Hint</div>
				}

				<RadzenProgressBar Value="@ProgressValue"
								   Min="0"
								   Max="100"
								   ShowValue="false"
								   class="hunt-progress" />

				<div class="compass-footer-actions">
					<RadzenButton Text="Oeuf trouve !"
								  Icon="egg_alt"
								  Click="@MarkCurrentTargetFoundAsync"
								  Disabled="@(HuntService.ActiveTarget is null)"
								  class="success-button compass-primary-action" />
					<RadzenButton Text="Actualiser"
								  Icon="explore"
								  ButtonStyle="ButtonStyle.Secondary"
								  Variant="Variant.Flat"
								  Click="@RefreshAsync" />
				</div>

				@if (HuntService.IsCompleted)
				{
					<div class="celebration-box">
						<h3>Bravo, tous les oeufs sont trouves !</h3>
						<p>Le lapin de Paques saute de joie.</p>
					</div>
				}
			</RadzenCard>
	</section>
	</section>

	@if (HuntService.IsCompleted)
	{
		<div class="confetti-rain" aria-hidden="true">
			<span></span>
			<span></span>
			<span></span>
			<span></span>
			<span></span>
			<span></span>
		</div>
	}
</div>

@code {
	private readonly PeriodicTimer _refreshTimer = new(TimeSpan.FromSeconds(1));
	private readonly CancellationTokenSource _refreshCts = new();
	private bool showTransition = true;
	private string? runtimeMessage;

	protected override async Task OnInitializedAsync()
	{
		HuntService.StateChanged += HandleStateChanged;
		try
		{
			await HuntService.InitializeAsync();

			if (!HuntService.HasTargets)
			{
				Navigation.NavigateTo(string.Empty, replace: true);
				return;
			}

			_ = PollAsync(_refreshCts.Token);
		}
		catch (Exception exception)
		{
			runtimeMessage = $"L'application n'a pas pu demarrer correctement : {exception.Message}";
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || !HuntService.HasTargets)
		{
			return;
		}

		await HuntService.ResumeSensorsAsync();
		await HuntService.TryEnterFullscreenAsync();
		await Task.Delay(2200);
		showTransition = false;
		await InvokeAsync(StateHasChanged);
	}

	private string HeroTitle => HuntService.IsCompleted
		? "Mission arc-en-ciel terminee !"
		: "La boussole te guide vers le prochain tresor";

	private string CompassTitle => HuntService.IsCompleted
		? "Tous les oeufs sont trouves"
		: "Vers le tresor";

	private double ProgressValue => HuntService.TotalCount == 0
		? 0
		: HuntService.FoundCount * 100d / HuntService.TotalCount;

	private async Task PollAsync(CancellationToken cancellationToken)
	{
		try
		{
			while (await _refreshTimer.WaitForNextTickAsync(cancellationToken))
			{
				await HuntService.RefreshAsync();
			}
		}
		catch (OperationCanceledException)
		{
		}
		catch (ObjectDisposedException)
		{
		}
		catch (Exception exception)
		{
			runtimeMessage = $"Le rafraichissement automatique a ete interrompu : {exception.Message}";
			await InvokeAsync(StateHasChanged);
		}
	}

	private void HandleStateChanged()
	{
		_ = InvokeAsync(StateHasChanged);
	}

	private async Task RefreshAsync()
	{
		await HuntService.RefreshAsync();
	}

	private async Task MarkCurrentTargetFoundAsync()
	{
		await HuntService.MarkCurrentTargetFoundAsync();
	}

	public void Dispose()
	{
		HuntService.StateChanged -= HandleStateChanged;
		_refreshCts.Cancel();
		_refreshTimer.Dispose();
		_refreshCts.Dispose();
	}
}
