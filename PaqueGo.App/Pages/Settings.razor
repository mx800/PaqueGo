@page "/"
@inject EggHuntService HuntService
@inject NavigationManager Navigation

<PageTitle>Chasse aux trésors de Pâque</PageTitle>

<div class="hunt-screen settings-screen">
	<div class="sky-layer">
		<span class="cloud cloud-one"></span>
		<span class="cloud cloud-two"></span>
		<span class="cloud cloud-three"></span>
		<span class="spark spark-one"></span>
		<span class="spark spark-two"></span>
		<span class="spark spark-three"></span>
	</div>

	<section class="settings-shell">
		<MudPaper Class="settings-hero hero-card mud-shell-card" Elevation="0">
			<div class="hero-copy">
				<h1>Chasse aux trésors de Pâque</h1>
				<MudText Typo="Typo.body1" Class="hero-text">Prépare les points de passage, compose les indices et lance l'aventure quand tout est prêt.</MudText>

				@if (!string.IsNullOrWhiteSpace(pageMessage))
				{
					<MudAlert Severity="@(pageMessageIsError ? Severity.Error : Severity.Success)"
							  Variant="Variant.Filled"
							  Dense="true"
							  Class="@($"upload-message mud-message {(pageMessageIsError ? "is-error" : "is-success")}")">
						@pageMessage
					</MudAlert>
				}
			</div>

			<div class="hero-visual settings-visual" aria-hidden="true">
				<div class="bunny-mascot">
					<div class="bunny-ear left"></div>
					<div class="bunny-ear right"></div>
					<div class="bunny-head">
						<span class="eye left"></span>
						<span class="eye right"></span>
						<span class="nose"></span>
						<span class="cheek left"></span>
						<span class="cheek right"></span>
					</div>
				</div>
				<div class="floating-egg egg-a"></div>
				<div class="floating-egg egg-b"></div>
				<div class="floating-egg egg-c"></div>
			</div>
		</MudPaper>

		<MudGrid>
			<MudItem xs="12" sm="6">
				<MudPaper Class="game-card settings-builder-card mud-shell-card" Elevation="0">
				<div class="card-head compact">
					<div>
						<h2>Enregistrement des points</h2>
					</div>
				</div>

				<div class="builder-form">
					<MudGrid Class="form-grid">
						<MudItem xs="12" md="6">
						<label class="form-field">
							<span class="metric-label">Nom du point</span>
							<MudTextField @bind-Value="pointName"
									  Placeholder="Ex. Oeuf doré"
									  Variant="Variant.Outlined"
									  Margin="Margin.Dense"
									  Immediate="true"
									  Class="mud-input-elevated" />
						</label>
						</MudItem>

						<MudItem xs="12" md="6">
						<label class="form-field">
							<span class="metric-label">Indice</span>
							<MudTextField @bind-Value="pointHint"
									  Placeholder="Ex. Près du banc"
									  Variant="Variant.Outlined"
									  Margin="Margin.Dense"
									  Immediate="true"
									  Class="mud-input-elevated" />
						</label>
						</MudItem>

						<MudItem xs="12" md="6">
						<label class="form-field">
							<span class="metric-label">Latitude</span>
							<MudNumericField T="double?"
										 @bind-Value="pointLatitude"
										 Step="0.000001"
										 Format="0.000000"
										 Variant="Variant.Outlined"
										 Margin="Margin.Dense"
										 Immediate="true"
										 HideSpinButtons="true"
										 Class="mud-input-elevated" />
						</label>
						</MudItem>

						<MudItem xs="12" md="6">
						<label class="form-field">
							<span class="metric-label">Longitude</span>
							<MudNumericField T="double?"
										 @bind-Value="pointLongitude"
										 Step="0.000001"
										 Format="0.000000"
										 Variant="Variant.Outlined"
										 Margin="Margin.Dense"
										 Immediate="true"
										 HideSpinButtons="true"
										 Class="mud-input-elevated" />
						</label>
						</MudItem>
					</MudGrid>

					<MudButton Variant="Variant.Filled"
							   Color="Color.Success"
							   StartIcon="@Icons.Material.Filled.Add"
							   OnClick="@AddPoint"
							   Disabled="@(!CanAddPoint)"
							   Class="success-button builder-add-button">
						Ajouter un point
					</MudButton>
				</div>
				</MudPaper>
			</MudItem>

			<MudItem xs="12" sm="6">
				<MudPaper Class="game-card settings-points-card mud-shell-card" Elevation="0">
				<div class="card-head compact">
					<div>
						<h2>Points enregistrés</h2>
					</div>
					<MudChip T="string" Class="target-chip" Color="Color.Primary" Variant="Variant.Filled">@configuredTargets.Count point(s)</MudChip>
				</div>

				@if (configuredTargets.Count == 0)
				{
					<MudPaper Class="empty-state-card" Elevation="0">
						<MudText Typo="Typo.h6">Ajoute ton premier point</MudText>
						<MudText Typo="Typo.body2">Chaque point a besoin d'un nom, d'une latitude et d'une longitude.</MudText>
					</MudPaper>
				}
				else
				{
					<div class="point-list">
						@foreach (var target in configuredTargets)
						{
							<MudPaper Class="point-item" Elevation="0">
								<div class="point-copy">
									<MudText Typo="Typo.h6">@target.Name</MudText>
									<MudText Typo="Typo.body2">@target.Latitude.ToString("0.000000"), @target.Longitude.ToString("0.000000")</MudText>
									@if (!string.IsNullOrWhiteSpace(target.Hint))
									{
										<MudText Typo="Typo.body2"><em>Indice : @target.Hint</em></MudText>
									}
								</div>
								<MudIconButton Icon="@Icons.Material.Filled.Delete"
										   Color="Color.Error"
										   Size="Size.Medium"
										   OnClick="@(() => RemovePoint(target.Id))" />
							</MudPaper>
						}
					</div>
				}

				@if (configuredTargets.Count > 0)
				{
					<div class="points-panel-actions">
						<MudButton Variant="Variant.Filled"
								   Color="Color.Primary"
								   StartIcon="@Icons.Material.Filled.Explore"
								   OnClick="@StartHuntAsync"
								   Class="cta-button points-start-button">
							Commencer la chasse
						</MudButton>
					</div>
				}
				</MudPaper>
			</MudItem>
		</MudGrid>
	</section>
</div>

@code {
	private readonly List<EggTarget> configuredTargets = [];
	private string pointName = string.Empty;
	private string pointHint = string.Empty;
	private double? pointLatitude;
	private double? pointLongitude;
	private string? pageMessage;
	private bool pageMessageIsError;

	private bool CanAddPoint =>
		!string.IsNullOrWhiteSpace(pointName) &&
		pointLatitude.HasValue &&
		pointLongitude.HasValue;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			await HuntService.InitializeAsync();
			configuredTargets.Clear();
			configuredTargets.AddRange(HuntService.Targets.Select(target => new EggTarget
			{
				Id = target.Id,
				Name = target.Name,
				Latitude = target.Latitude,
				Longitude = target.Longitude,
				Hint = target.Hint
			}));
		}
		catch (Exception exception)
		{
			pageMessageIsError = true;
			pageMessage = $"La configuration n'a pas pu être chargée : {exception.Message}";
		}
	}

	private void AddPoint()
	{
		if (!CanAddPoint)
		{
			pageMessageIsError = true;
			pageMessage = "Renseigne le nom, la latitude et la longitude avant d'ajouter un point.";
			return;
		}

		configuredTargets.Add(new EggTarget
		{
			Id = Guid.NewGuid().ToString("N"),
			Name = pointName.Trim(),
			Latitude = pointLatitude.GetValueOrDefault(),
			Longitude = pointLongitude.GetValueOrDefault(),
			Hint = string.IsNullOrWhiteSpace(pointHint) ? null : pointHint.Trim()
		});

		pointName = string.Empty;
		pointHint = string.Empty;
		pointLatitude = null;
		pointLongitude = null;
		pageMessageIsError = false;
		pageMessage = "Le point a été ajouté à la chasse.";
	}

	private void RemovePoint(string pointId)
	{
		var index = configuredTargets.FindIndex(target => target.Id == pointId);

		if (index < 0)
		{
			return;
		}

		configuredTargets.RemoveAt(index);
		pageMessage = null;
		pageMessageIsError = false;
	}

	private async Task StartHuntAsync()
	{
		try
		{
			await HuntService.LoadConfiguredTargetsAsync(configuredTargets, "Configuration organisateur");
			await HuntService.StartAdventureAsync();
			Navigation.NavigateTo("hunt", replace: true);
		}
		catch (Exception exception)
		{
			pageMessageIsError = true;
			pageMessage = exception.Message;
		}
	}
}